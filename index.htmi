<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="เว็บไซต์แสดงผลงานและทักษะของ Pattaratida">
    <title>ความภาคภูมิใจของ PATTARATIDA</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- ส่วนหัวของเว็บ -->
    <header>
        <h1>สวัสดี! หนูคือ PATTARATIDA</h1>
        <p>นี่คือผลงานและความภาคภูมิใจของหนู</p>
    </header>

    <!-- ส่วนเกี่ยวกับตัวเอง -->
    <section id="about">
        <h2>เกี่ยวกับหนู</h2>
        <p>หนูชอบภาษาและวัฒนธรรมของญี่ปุ่นผ่านสื่อต่าง ๆ เช่น เพลง อนิเมะ และรายการโทรทัศน์ของญี่ปุ่น รวมถึงการฝึกอ่านและเรียนรู้คำศัพท์ใหม่ ๆ อยู่เสมอ เพื่อพัฒนาทักษะทางภาษาและเพิ่มความเข้าใจเกี่ยวกับวัฒนธรรมญี่ปุ่น</p>
    </section>

    <!-- ส่วนแสดงผลงาน -->
    <section id="projects">
        <h2>ผลงานของหนู</h2>

        <div class="project">
            <h3>เว็บไซต์ Portfolio</h3>
            <p>เว็บไซต์นี้เป็นหนึ่งในผลงานที่หนูสร้างขึ้นเพื่อแสดงความสามารถของหนู</p>
        </div>

        <div class="project">
            <h3>แอปพลิเคชันจัดการงาน</h3>
            <p>แอปพลิเคชันที่ช่วยให้ผู้ใช้งานจัดการงานได้อย่างมีประสิทธิภาพ</p>
        </div>
    </section>

    <!-- ส่วนแสดงทักษะ -->
    <section id="skills">
        <h2>ทักษะของหนู</h2>
        <ul>
            <li>ร้องเพลงได้</li>
            <li>วาดรูปได้</li>
            <li>มีทักษะความรู้ด้านภาษาและวัฒนธรรมญี่ปุ่น</li>
            <li>สามารถทำงานร่วมกับผู้อื่นได้</li>
        </ul>
    </section>

    <!-- ส่วนติดต่อและลิขสิทธิ์ -->
    <footer>
        <p>ติดต่อหนูได้:
            <a href="mailto: sodapattaratida@gmail.com">sodapattaratida@gmail.com</a>
        </p>
        <p>&copy; <span id="year"></span> PATTARATIDA. All rights reserved. </p>
    </footer>

    <!-- ลิงก์ไปยัง JavaScript -->
    <script src="script.js"></script>

</body>
</html>
